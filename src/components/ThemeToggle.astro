---
import { Image } from "astro:assets";
import light from "../assets/light.svg";
import dark from "../assets/dark.svg";
---

<button
    id="themeToggle"
    class="p-2 rounded-lg border border-neutral-300 dark:border-neutral-700 transition-colors hover:bg-neutral-100 dark:hover:bg-neutral-900"
    aria-label="Toggle theme"
>
    <Image
        src={light}
        alt="light mode"
        width={20}
        height={20}
        class="icon-sun block dark:hidden"
    />
    <Image
        src={dark}
        alt="dark mode"
        width={20}
        height={20}
        class="icon-moon hidden dark:block"
    />
</button>

<script is:inline>
    const currentTheme =
        localStorage.getItem("theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");

    if (currentTheme === "dark") {
        document.documentElement.classList.add("dark");
    } else {
        document.documentElement.classList.remove("dark");
    }

    localStorage.setItem("theme", currentTheme);

    document.getElementById("themeToggle")?.addEventListener("click", () => {
        const root = document.documentElement;
        const isDark = root.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
    });
</script>
