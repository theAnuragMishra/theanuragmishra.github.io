---
const pathname = Astro.url.pathname;
const highlight = (href: string) => {
    return href === "/" ? pathname === "/" : pathname.startsWith(href);
};
---

<nav class="text-sm font-medium">
    <ul class="flex flex-col md:flex-row md:justify-end text-center">
        <li>
            <a
                href="/writing"
                class={`block px-4 py-2  ${highlight("/writing") ? "" : ""}`}
            >
                Writing
            </a>
        </li>
        <li>
            <a
                href="/projects"
                class={`block px-4 py-2  ${highlight("/projects") ? "" : ""}`}
            >
                Projects
            </a>
        </li>
    </ul>
</nav>
