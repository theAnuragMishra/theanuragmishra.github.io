---
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname;
const highlight = (href: string) => {
    return href === "/" ? pathname === "/" : pathname.startsWith(href);
};
---

<header
    class="bg-white/80 dark:bg-neutral-950/80 backdrop-blur supports-backdrop-filter:bg-opacity-60"
>
    <nav class="mx-auto flex items-center justify-between md:px-4 py-4">
        <a href="/" class={`text-lg normal-link font-semibold`}> anurag. </a>

        <div class="flex items-center gap-2">
            <ul class="text-sm font-medium flex">
                <li>
                    <a
                        href="/writing"
                        class={`normal-link block md:mx-4 m-1 ${highlight("/writing") ? "" : ""}`}
                    >
                        Writing
                    </a>
                </li>
                <li>
                    <a
                        href="/projects"
                        class={`normal-link block md:mx-4 m-1 ${highlight("/projects") ? "" : ""}`}
                    >
                        Projects
                    </a>
                </li>
            </ul>
            <ThemeToggle />
        </div>
    </nav>
</header>
