---
import BaseLayout from "../../layouts/Layout.astro";
import { getSortedPosts } from "../../utils/content-utils";

export async function getStaticPaths() {
    const allPosts = await getSortedPosts();
    const uniqueTopics = [
        ...new Set(allPosts.map((post: any) => post.data.topics ?? []).flat()),
    ];

    return uniqueTopics.map((topic) => {
        const filteredPosts = allPosts.filter((post: any) =>
            post.data.topics?.includes(topic),
        );
        return {
            params: { topic },
            props: { posts: filteredPosts },
        };
    });
}

const { topic } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout
    pageTitle={`Topic: ${topic}`}
    description={`All blog posts on ${topic} by Anurag Kumar Mishra.`}
>
    <section class="max-w-3xl mx-auto px-4 py-12">
        <header class="mb-8">
            <h1
                class="text-3xl md:text-4xl font-semibold tracking-tight mb-2 capitalize"
            >
                {topic}
            </h1>
            <p class="text-neutral-600 dark:text-neutral-400">
                Posts tagged under “{topic}”.
            </p>
        </header>

        {
            posts.length > 0 ? (
                <ul class="space-y-4">
                    {posts.map((post: any) => (
                        <li>
                            <a
                                href={`/posts/${post.id}/`}
                                class="block border border-neutral-300 dark:border-neutral-700 rounded-xl p-4 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
                            >
                                <h2 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-1">
                                    {post.data.title}
                                </h2>

                                {post.data.description && (
                                    <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-1">
                                        {post.data.description}
                                    </p>
                                )}

                                <p class="text-xs text-neutral-500 dark:text-neutral-500">
                                    {post.data.pubDate.toLocaleDateString(
                                        undefined,
                                        {
                                            year: "numeric",
                                            month: "short",
                                            day: "numeric",
                                        },
                                    )}
                                </p>
                            </a>
                        </li>
                    ))}
                </ul>
            ) : (
                <p class="text-neutral-500 dark:text-neutral-400">
                    No posts found for this topic yet.
                </p>
            )
        }
    </section>
</BaseLayout>
