---
import Layout from "../layouts/Layout.astro";
import profileImg from "../assets/pfp.webp";
import svelteImg from "../assets/svelte.svg";
import reactImg from "../assets/react.svg";
import nextImg from "../assets/next.svg";
import dockerImg from "../assets/docker.svg";
import ghaImg from "../assets/gha.svg";
import goImg from "../assets/go.svg";
import expressImg from "../assets/express.svg";
import nodeImg from "../assets/node.svg";
import pgImg from "../assets/postgres.svg";
import redisImg from "../assets/redis.svg";
import mongoImg from "../assets/mongodb.svg";
import mccImg from "../assets/mcc-logo.webp";
import mbImg from "../assets/mnnit-buzz.webp";
---

<Layout pageTitle="Anurag Mishra">
    <div class="max-w-3xl mx-auto px-4 py-12 space-y-16">
        <!-- INTRO -->
        <section id="home" class="text-center space-y-4">
            <img
                src={profileImg.src}
                alt="Profile"
                class="mx-auto rounded-full w-32 h-32 object-cover ring-1 ring-neutral-300 dark:ring-neutral-700"
            />
            <h1 class="text-3xl md:text-4xl font-mono font-semibold">
                Anurag Kumar Mishra
            </h1>
            <p
                class="text-neutral-600 dark:text-neutral-400 text-sm md:text-base"
            >
                India-based Programmer & Chessy
            </p>
        </section>

        <!-- EDUCATION -->
        <section id="education">
            <h2
                class="text-xl font-mono font-semibold mb-4 border-b border-neutral-200 dark:border-neutral-700 pb-2"
            >
                Education
            </h2>
            <ul class="space-y-2 text-neutral-700 dark:text-neutral-300">
                <li class="flex justify-between text-sm md:text-base">
                    <span>B.Tech., MNNIT Allahabad</span>
                    <i>2023–2027</i>
                </li>
                <li class="flex justify-between text-sm md:text-base">
                    <span>12th, Lord Buddha Public School</span>
                    <i>2023</i>
                </li>
                <li class="flex justify-between text-sm md:text-base">
                    <span>10th, Lord Buddha Public School</span>
                    <i>2021</i>
                </li>
            </ul>
        </section>

        <!-- SKILLS -->

        <section id="skills" class="my-12">
            <h2
                class="text-2xl font-mono font-semibold mb-8 border-b border-neutral-300 dark:border-neutral-700 pb-3 tracking-tight"
            >
                Technical Skills
            </h2>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                {
                    [
                        {
                            title: "Frontend",
                            skills: [
                                { icon: svelteImg, label: "Svelte / Kit" },
                                { icon: reactImg, label: "React" },
                                { icon: nextImg, label: "Next.js" },
                            ],
                        },
                        {
                            title: "Backend",
                            skills: [
                                { icon: goImg, label: "Go" },
                                { icon: nodeImg, label: "Node.js" },
                                {
                                    icon: expressImg,
                                    label: "Express",
                                    id: "express",
                                },
                            ],
                        },
                        {
                            title: "Database",
                            skills: [
                                { icon: pgImg, label: "PostgreSQL" },
                                { icon: mongoImg, label: "MongoDB" },
                                { icon: redisImg, label: "Redis" },
                            ],
                        },
                        {
                            title: "DevOps",
                            skills: [
                                { icon: dockerImg, label: "Docker" },
                                { icon: ghaImg, label: "GitHub Actions" },
                            ],
                        },
                    ].map((group) => (
                        <div class="group border border-neutral-200 dark:border-neutral-800 rounded-2xl p-5 bg-neutral-50/50 dark:bg-neutral-900/50 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors duration-200 shadow-sm hover:shadow-md">
                            <h3 class="font-semibold mb-4 text-neutral-800 dark:text-neutral-100 text-lg flex items-center gap-2">
                                <span class="h-1.5 w-1.5 bg-blue-500 dark:bg-blue-400 rounded-full" />
                                {group.title}
                            </h3>
                            <ul class="space-y-2 text-neutral-700 dark:text-neutral-300 ml-2">
                                {group.skills.map(({ icon, label, id }) => (
                                    <li class="flex items-center gap-2 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">
                                        <img
                                            src={icon.src}
                                            alt={label}
                                            class="w-5 h-5 opacity-80 group-hover:opacity-100 transition-opacity"
                                            id={id}
                                        />
                                        <span class="text-sm">{label}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </section>

        <!-- PROJECTS -->

        <section id="projects" class="my-12">
            <h2
                class="text-2xl font-mono font-semibold mb-8 border-b border-neutral-300 dark:border-neutral-700 pb-3 tracking-tight"
            >
                Projects
            </h2>

            <div class="grid md:grid-cols-2 gap-8">
                {
                    [
                        {
                            img: mccImg,
                            title: "mnnitchessclub.com",
                            desc: "A chess server and frontend supporting PvP and tournaments.",
                            link: "https://mnnitchessclub.com",
                            text: "View Live →",
                            id: "mcc",
                        },
                        {
                            img: mbImg,
                            title: "MNNIT Buzz",
                            desc: "A Reddit-like social app for MNNIT.",
                            link: "https://mnnit-buzz.vercel.app",
                            text: "View Live →",
                            id: "mb",
                        },
                        {
                            title: "cfgen",
                            desc: "A Codeforces contest scraper automating setup.",
                            link: "https://github.com/theAnuragMishra/cfgen",
                            text: "View on GitHub →",
                            id: "cfgen",
                        },
                    ].map((proj) => (
                        <article class="group border border-neutral-200 dark:border-neutral-800 rounded-2xl p-6 bg-neutral-50/60 dark:bg-neutral-900/60 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all duration-300 shadow-sm hover:shadow-md flex flex-col justify-between">
                            {proj.img && (
                                <div class="mb-4">
                                    <img
                                        src={proj.img.src}
                                        alt={proj.title}
                                        class="h-12 rounded-md shadow-sm opacity-90 group-hover:opacity-100 transition-opacity"
                                        id={proj.id}
                                    />
                                </div>
                            )}

                            <div class="flex-1">
                                <h3 class="font-mono font-semibold text-lg text-neutral-800 dark:text-neutral-100 mb-2 group-hover:text-neutral-900 dark:group-hover:text-neutral-50 transition-colors">
                                    {proj.title}
                                </h3>
                                <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed mb-5">
                                    {proj.desc}
                                </p>
                            </div>

                            <a
                                href={proj.link}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center text-sm font-medium text-neutral-700 dark:text-neutral-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors group-hover:translate-x-1 duration-200"
                            >
                                {proj.text}
                            </a>
                        </article>
                    ))
                }
            </div>
        </section>

        <!-- CONTACT -->

        <section
            id="contact"
            class="text-center flex flex-col items-center space-y-6"
        >
            <h2
                class="text-2xl font-mono font-semibold border-b border-neutral-300 dark:border-neutral-700 pb-3 mb-2 tracking-tight"
            >
                Contact
            </h2>

            <p
                class="text-neutral-700 dark:text-neutral-300 max-w-md leading-relaxed"
            >
                Reach out at
                <a
                    href="mailto:yoiam420@gmail.com"
                    class="ml-1 underline decoration-neutral-400 dark:decoration-neutral-600 underline-offset-4 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                >
                    yoiam420@gmail.com
                </a>
            </p>

            <div
                class="flex flex-wrap justify-center items-center gap-6 text-sm text-neutral-600 dark:text-neutral-400"
            >
                <a
                    href="https://github.com/theAnuragMishra"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
                >
                    GitHub
                </a>
                <a
                    href="https://x.com/giuocopianosimp"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
                >
                    Twitter
                </a>
                <a
                    href="https://www.linkedin.com/in/the-anurag-mishra/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
                >
                    LinkedIn
                </a>
            </div>
        </section>
    </div>
</Layout>
<style>
    :global(.dark) #mcc,
    :global(.dark) #aura,
    :global(.dark) #express {
        filter: invert(1);
    }
</style>
