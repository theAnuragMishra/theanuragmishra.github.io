---
import BaseLayout from "../layouts/Layout.astro";
---

<BaseLayout
    pageTitle="Page Not Found"
    description="404 page for Anurag Kumar Mishra's personal website"
>
    <section
        class="flex flex-col items-center justify-center min-h-[60vh] text-center px-6"
    >
        <h1 class="text-4xl md:text-5xl font-semibold mb-4">404</h1>

        <p class="text-neutral-600 dark:text-neutral-400 mb-1">
            Looks like you’re lost — I didn't create a page here.
        </p>

        <a href="/" class="rounded-md text-neutral-800 dark:text-neutral-200">
            Go back home!
        </a>
    </section>
</BaseLayout>
